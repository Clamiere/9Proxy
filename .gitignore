# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# omc
.omc/

# packages / apps / services
packages/*/node_modules
packages/*/dist
apps/*/node_modules
apps/*/.next
apps/*/dist
services/*/node_modules
services/*/dist

# verification reports (kept local only, re-generated by pipeline)
verification-report.json
deep-verification-report.json
enrichment-report.json
signup-url-report.json

# playwright auth (never commit)
.playwright-auth.json

# typescript
*.tsbuildinfo
next-env.d.ts
apps/*/next-env.d.ts

# supabase local
supabase/.branches
supabase/.temp
supabase/volumes

# remotion — large media files, not source
remotion/launch-video.mp4
remotion/public/*.mp4
remotion/public/*.mp3
remotion/node_modules
remotion/out
reports/
